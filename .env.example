# CompleteAI Enterprise Environment Variables

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/completeai
REDIS_URL=redis://localhost:6379

# Vector DB
WEAVIATE_URL=http://localhost:8080
WEAVIATE_API_KEY=your-weaviate-key

# LLMs
OLLAMA_BASE_URL=http://localhost:11434
GROK_API_KEY=xai-your-grok-api-key
OPENAI_API_KEY=sk-your-openai-key

# Auth
SECRET_KEY=your-super-secret-key-generate-with-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30

# External Tools
TAVILY_API_KEY=your-tavily-key-for-web-search
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# LangSmith (optional monitoring)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=ls-your-key
LANGCHAIN_PROJECT=completeai-enterprise

# Production
DEBUG=false
