# =========================================================================
# CONFIGURATION FOR CLOUD DEPLOYMENT (RENDER / STREAMLIT CLOUD)
# =========================================================================

# 1. LLM Settings (Free API Keys)
# Get GROQ key here: https://console.groq.com/keys
# Get GEMINI key here: https://aistudio.google.com/app/apikey
LLM_ENGINE=groq
GROQ_API_KEY=your_groq_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
LLM_MODEL_NAME=llama3-8b-8192

# 2. Database & Vector DB (Supabase)
# Get these values from your Supabase Project Settings -> API & Database
# Connection string: postgresql+asyncpg://[user]:[password]@[host]:[port]/[db]
DATABASE_URL=postgresql+asyncpg://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-ID].supabase.co:6543/postgres
SUPABASE_URL=https://[YOUR-PROJECT-ID].supabase.co
SUPABASE_KEY=your_supabase_anon_key

# 3. Streamlit Frontend (If running locally, set to http://127.0.0.1:8000)
# If deploying Streamlit on Cloud, set this to your Render.com Backend URL
BACKEND_URL=https://my-backend-app-on-render.onrender.com
